{
  "name": "cleanshot-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute cleanshot --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute cleanshot --remote --file=./migrations/0001_init.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.0.0"
  }
}
