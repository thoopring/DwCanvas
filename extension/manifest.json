{
  "manifest_version": 3,
  "name": "CleanShot",
  "version": "2.0.0",
  "description": "Turn any YouTube video into a publish-ready LinkedIn carousel in 30 seconds.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "contextMenus",
    "identity"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://cleanshot-api.thoopring.workers.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open CleanShot"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "oauth2": {
    "client_id": "470234984264-hvp7lae3el3lgdh7h621sogvne65aemf.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
