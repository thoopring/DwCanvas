{
  "manifest_version": 3,
  "name": "CleanShot for YouTube: Capture & Insight",
  "version": "1.0.6",
  "description": "Capture clean screenshots without UI, save timestamps, and generate AI insights for LinkedIn.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open CleanShot"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}